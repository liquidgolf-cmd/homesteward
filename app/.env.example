# Firebase (client) — realestatebuddy2. Paste ONLY the value, no quotes, no extra text.
# Firebase Console → Project settings → Your apps → Web app → copy each field exactly.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

