\f7\fs26 \cf0 \
function canPerformLookup(agent_id):\
    used = sum_lookup_cost(agent_id, billing_period_start, now)\
    quota = agent_quota(agent_id)  # number of lookups allowed\
    if used < quota*0.75:\
        return \{allowed: true, reason: "ok"\}\
    if used >= quota*0.75 and used < quota:\
        alertAgent("75%")\
        return \{allowed: true, reason: "near_limit"\}\
    if used >= quota:\
        return \{allowed: false, reason: "quota_exceeded"\}\
\
